# grokcli-2api environment template
# 1) Copy:  cp .env.example .env
# 2) Edit secrets below
# 3) Start: ./start.sh   or   docker compose up -d --build
#
# Docker Compose loads .env via env_file.
# Local production override may use: cp .env.example grokcli-2api.env
# (grokcli-2api.env is gitignored — never commit real secrets)

# ── Core ──────────────────────────────────────────────
GROK2API_HOST=0.0.0.0
GROK2API_PORT=3000
GROK2API_OPEN_BROWSER=0
GROK2API_ADMIN_PASSWORD=change-me
# GROK2API_PUBLIC_BASE_URL=
# GROK2API_DATA_DIR=./data
# GROK2API_API_KEY=
GROK2API_REQUIRE_API_KEY=1
# GROK2API_REQUIRE_API_KEY=auto  # local only; server must be 1
GROK2API_DEFAULT_MODEL=grok-4.5
GROK2API_ACCOUNT_MODE=round_robin

# ── Relay / Claude Code / sub2api ─────────────────────
# off (recommended): keep reasoning in reasoning_content
# think_tag: wrap as <think> into content (content-only relays)
# content: merge reasoning into content without tags
GROK2API_REASONING_COMPAT=off
GROK2API_SSE_KEEPALIVE=8

# Long tool-loop history compaction (OFF by default).
# Only enable if CC multi-round Read/Bash bodies grow huge (400KB+) and upstream times out.
# When on: keeps latest N tool rounds; older tool_result → short placeholder.
GROK2API_HISTORY_COMPACT=0
# GROK2API_HISTORY_KEEP_TOOL_ROUNDS=6
# GROK2API_HISTORY_MAX_TOOL_RESULT_CHARS=12000
# GROK2API_HISTORY_MAX_MESSAGES_CHARS=280000
# Cap tools per assistant turn (default 1). Avoids sub2api multi-block races.
# GROK2API_OUTBOUND_MAX_TOOLS=1
# Set 0 only if client is pure OpenAI (not Claude Code via sub2api)
# GROK2API_OUTBOUND_MAX_TOOLS=0
# Real delay (seconds) between consecutive tool SSE frames. Keepalive alone is
# not enough when sub2api drains a TCP window of multi-tool chunks in one tick.
# GROK2API_OUTBOUND_TOOL_GAP_SEC=0.08

# ── Token maintain / model health ─────────────────────
GROK2API_TOKEN_MAINTAIN=1
GROK2API_MODEL_HEALTH=1
# GROK2API_TOKEN_MAINTAIN_INTERVAL=180
# GROK2API_MODEL_HEALTH_INTERVAL=900
# GROK2API_TOKEN_REFRESH_WORKERS=2
# GROK2API_MODEL_PROBE_WORKERS=2
# GROK2API_TOKEN_REFRESH_BATCH=20
# GROK2API_MODEL_PROBE_BATCH=15

# ── Protocol registration (optional) ──────────────────
# GROK2API_MOEMAIL_API_KEY=
# GROK2API_MOEMAIL_BASE_URL=https://moemail.example.com
# GROK2API_MOEMAIL_DOMAIN=example.com
# GROK2API_MOEMAIL_EXPIRY_MS=3600000
# GROK2API_YESCAPTCHA_KEY=
# GROK2API_XAI_PROXY=
# GROK2API_RUYIPAGE_APPROVER=http://ruyipage-approver:8765
# GROK2API_REG_MAX_CONCURRENCY=1

# ── Continuous server producer (docker-compose.server.yml) ─────
# Keep producer concurrency aligned with the number of independent ruyiPage
# sidecars; extra workers mainly increase queueing and xAI rate-limit risk.
# GROK2API_PRODUCER_BATCH_SIZE=1
# GROK2API_PRODUCER_CONCURRENCY=1
# GROK2API_PRODUCER_STAGGER_MS=1500
# GROK2API_PRODUCER_COOLDOWN_SEC=45
# GROK2API_PRODUCER_BATCH_TIMEOUT_SEC=1800
# Keep this many enabled, unexpired, renewable, non-quota-disabled accounts.
# GROK2API_PRODUCER_TARGET_ACCOUNTS=5000
# GROK2API_PRODUCER_TARGET_MODEL=grok-4.5
# GROK2API_PRODUCER_POOL_CHECK_SEC=60
# Permanent-failure cleanup is conservative and observation-only by default.
# Inspect dry-run logs before explicitly changing DRY_RUN to 0 in production.
# GROK2API_PRODUCER_CLEANUP_ENABLED=1
# GROK2API_PRODUCER_CLEANUP_DRY_RUN=1
# GROK2API_PRODUCER_CLEANUP_MIN_AGE_SEC=21600
# GROK2API_PRODUCER_CLEANUP_CONFIRMATIONS=3
# GROK2API_PRODUCER_CLEANUP_CONFIRM_WINDOW_SEC=900
# GROK2API_PRODUCER_CLEANUP_BATCH_SIZE=100
# Automatically recover registrations that obtained SSO but failed Device Flow.
# Keep 0 on registration-producer; only pending-recovery container enables recovery.
# GROK2API_PENDING_RECOVERY=0
GROK2API_PENDING_MIN_AGE_SEC=120
GROK2API_PENDING_MAX_PER_CYCLE=2
GROK2API_PENDING_RETRY_BASE_SEC=120
GROK2API_PENDING_RETRY_MAX_SEC=3600
# Cross-container, per-sidecar leases. Keep this path on the shared data volume.
# GROK2API_APPROVER_LOCK_DIR=/app/data/approver_locks
# GROK2API_APPROVER_LOCK_WAIT_SEC=150
# GROK2API_APPROVER_LOCK_POLL_SEC=0.25

# ── Registration pipeline v2 (defaults preserve legacy behaviour) ───────────
# See docs/GROK_REGISTRATION_SPEED_OPTIMIZATION_PLAN.md for staged rollout.
# GROK2API_PIPELINE_V2=0
# GROK2API_ROUTE_STICKY=0
# GROK2API_COOKIE_MODE=sso_only
# GROK2API_COOKIE_EXPERIMENT_PERCENT=0
# GROK2API_COOKIE_ALLOW_CF=0
# GROK2API_COOKIE_BUNDLE_DIR=/app/data/cookie_bundles
# GROK2API_COOKIE_BUNDLE_TTL_SEC=7200
# GROK2API_RUYIPAGE_WARM_BROWSER=0
# GROK2API_RUYIPAGE_RECYCLE_TASKS=10
# GROK2API_RUYIPAGE_RECYCLE_SEC=5400
# GROK2API_RUYIPAGE_POLL_MS=200
# GROK2API_PARALLEL_TOKEN_POLL=0
# GROK2API_ADAPTIVE_SCHEDULER=0
# GROK2API_REGISTRATION_QUEUE_SOFT_LIMIT=12
# GROK2API_REGISTRATION_QUEUE_HARD_LIMIT=30
# GROK2API_REGISTRATION_QUEUE_DB=/app/data/registration_queue.db
# GROK2API_REGISTRATION_METRICS_DB=/app/data/registration_metrics.db
# GROK2API_METRICS_ENABLED=1
# GROK2API_MINT_MAX_ATTEMPTS=5
# GROK2API_MINT_SKIP_PROBE=0
# Enable mint worker container with: GROK2API_PRODUCER_MODE=mint
# Route proxies (used when ROUTE_STICKY=1):
# GROK2API_ROUTE1_PROXY=http://grok-mihomo:7890
# GROK2API_ROUTE2_PROXY=http://grok-mihomo-2:7890
# Align API CPU budget toward 0.40 when co-locating with dual approvers:
# GROK2API_API_CPUS=0.40
